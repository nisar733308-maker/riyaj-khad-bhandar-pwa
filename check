<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>रियाज अहमद खाद भंडार</title>

  <!-- Main CSS -->
  <link rel="stylesheet" href="./style.css" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://images.unsplash.com">

  <style>
    :root {
      --primary: #004831;
      --accent: #E0A92E;
    }

    /* Side Menu */
    .side-menu {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      display: none;
      z-index: 10000;
      backdrop-filter: blur(4px);
    }

    .menu-content {
      position: absolute;
      right: 0;
      width: 280px;
      height: 100%;
      background: var(--bg-card, #fff);
      box-shadow: -5px 0 15px rgba(0,0,0,0.1);
      display: flex;
      flex-direction: column;
      animation: slideIn .3s ease;
    }

    @keyframes slideIn {
      from { transform: translateX(100%); }
      to { transform: translateX(0); }
    }

    .menu-list li {
      padding: 14px 20px;
      display: flex;
      gap: 12px;
      cursor: pointer;
      border-bottom: 1px solid #f0f0f0;
    }

    .menu-list li:hover {
      background: #f1f8e9;
    }

    .dark-mode .menu-content {
      background: #1e1e1e;
      color: #fff;
    }

    .hero {
      background: linear-gradient(rgba(0,72,49,0.8), rgba(0,72,49,0.8)),
      url('https://images.unsplash.com/photo-1585314062340-f1a5a7c9328d?auto=format&fit=crop&q=80&w=1200');
      background-size: cover;
      padding: 60px 20px;
      text-align: center;
      color: white;
    }

    .hero button {
      padding: 14px 30px;
      font-weight: bold;
      cursor: pointer;
      border-radius: 4px;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--primary);
      border: none;
    }

    .btn-outline {
      border: 2px solid white;
      background: transparent;
      color: white;
    }
  </style>
</head>

<body>

<!-- Toast -->
<div id="toast-container"></div>

<!-- Header -->
<header class="header">
  <div class="header-left">
    <span class="logo">🌾</span>
    <div>
      <h1 id="shop-title">रियाज अहमद खाद भंडार</h1>
      <p id="shop-desc">Indian Farmers' Trusted Partner</p>
    </div>
  </div>

  <button id="menu-btn" aria-label="Menu">☰</button>
</header>

<!-- Hero -->
<section class="hero">
  <h2>मिट्टी की जान, किसान की शान</h2>
  <p>
    उच्च गुणवत्ता वाले उर्वरक और बीज — किसान की समृद्धि के लिए।
  </p>

  <div style="margin-top:20px;">
    <button class="btn-primary" onclick="document.getElementById('products-container').scrollIntoView({behavior:'smooth'})">
      खरीदारी करें
    </button>
    <button class="btn-outline" onclick="location.href='about.html'">
      हमारे बारे में
    </button>
  </div>
</section>

<!-- Commitment -->
<section class="commitment">
  <h3>हमारा संकल्प</h3>
  <p>शुद्ध खाद, सही दाम और किसान का सम्मान।</p>
</section>

<!-- Side Menu -->
<div id="side-menu" class="side-menu">
  <div class="menu-content" id="menu-content">
    
    <div class="menu-header-prof">
      <div class="profile-avatar">👤</div>
      <h3 id="menu-user-greeting">नमस्ते</h3>
    </div>

    <ul class="menu-list">
      <li>
        🌐
        <select id="app-lang">
          <option value="hi">हिन्दी</option>
          <option value="en">English</option>
        </select>
      </li>

      <li id="menu-login">🔑 लॉगिन</li>
      <li id="menu-profile" style="display:none;">👤 प्रोफाइल</li>
      <li id="menu-orders">📜 ऑर्डर</li>
      <li id="dark-mode-toggle">🌙 डार्क मोड</li>
      <li onclick="location.href='admin.html'">🛠️ एडमिन</li>
    </ul>

    <div class="menu-footer-info">
      © 2004 रियाज अहमद खाद भंडार
    </div>

  </div>
</div>

<!-- Filters -->
<nav>
  <input id="search" placeholder="खोजें..." />
  <select id="category-filter"></select>
  <select id="rating-filter"></select>
  <select id="sort-filter"></select>
  <button id="clear-filters-btn">Clear</button>
  <span id="cart-count">🛒 0</span>
</nav>

<!-- Slider -->
<div id="featured-slider">
  <div id="slider-wrapper"></div>
</div>

<!-- Products -->
<main id="products-container"></main>

<!-- Footer -->
<footer>
  <small>V 1.2.0</small>
</footer>

<!-- Firebase -->
<script defer src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
<script defer src="https://www.gstatic.com/firebasejs/9.6.1/firebase-database-compat.js"></script>
<script defer src="https://www.gstatic.com/firebasejs/9.6.1/firebase-auth-compat.js"></script>

<script defer src="./firebaseConfig.js"></script>
<script defer src="./products.js"></script>
<script defer src="./cart.js"></script>
<script defer src="./app.js"></script>

<!-- Optimized JS -->
<script>
  // Menu toggle (optimized)
  const menu = document.getElementById("side-menu");
  const menuBtn = document.getElementById("menu-btn");

  menuBtn.addEventListener("click", () => {
    menu.style.display = "block";
  });

  menu.addEventListener("click", (e) => {
    if (e.target === menu) {
      menu.style.display = "none";
    }
  });

  // Language change
  document.getElementById("app-lang").addEventListener("change", e => {
    window.changeLanguage?.(e.target.value);
  });

  // Dark mode
  document.getElementById("dark-mode-toggle").addEventListener("click", () => {
    document.body.classList.toggle("dark-mode");
  });

</script>

</body>
</html>